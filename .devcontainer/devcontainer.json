{
  "name": "pantheon-sitehealth-emails Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Detroit}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2"
    }
  },
  "runArgs": [
    "--shm-size=1g",
    "--security-opt=seccomp=unconfined",
    // Docker Desktop's resolver (192.168.65.7) answers every AAAA query with NODATA, so
    // dns_classify would see IPv6-only records as absent.  Use public resolvers instead;
    // --add-host preserves host.docker.internal, which that resolver used to provide.
    "--dns=1.1.1.1",
    "--dns=8.8.8.8",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=python-venv-${devcontainerId},target=/workspace/.venv,type=volume"
  ],
  "containerEnv": {
    "CLOUDFLARE_EMAIL": "${localEnv:CLOUDFLARE_EMAIL}",
    "CLOUDFLARE_API_KEY": "${localEnv:CLOUDFLARE_API_KEY}",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "mise install",
  "postStartCommand": "sudo /usr/local/bin/container-start.sh",
  "waitFor": "postStartCommand"
}
