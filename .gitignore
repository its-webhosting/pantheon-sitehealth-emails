# pantheon-sitehealth-emails script stuff
/pantheon-sitehealth-emails.toml
/pantheon-sitehealth-emails-config
/local.toml
/database.db
/.devcontainer/ssh/keys/**
/.devcontainer/terminus/cache/tokens/**

/site_results.json
/fqdns.json
/news/*.toml
/build/
/tmp/
*.csv
*-results.json

# Agent working state: tickets and wayfinding maps are ephemeral.
# Specs/plans are NOT here — they belong in development/ (see docs/agents/issue-tracker.md)
/.scratch/

# Claude development archive: keep scrubbed artifacts, never raw exports or logs
/development/**/*.raw.txt
/development/**/*.raw.md
/development/**/*.jsonl

# Editor backup and temporary files
.*.swp
*~

# macOS stuff
.DS_Store
/.idea/

# Logs
logs/
*.log

# Python stuff
/venv/
/.venv/
/pantheon_sitehealth_emails.egg-info/
**/__pycache__/
*.pyc

# Test harness working data
/.pytest_cache/
/.coverage
/.hypothesis/

# PHP stuff
/vendor/
# don't commit composer.lock since different people may be using
# different versions of PHP, which in turn cause differences in
# composer package dependencies
composer.lock

# dotenv environment variables files
.env*
