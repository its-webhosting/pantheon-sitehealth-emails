#!/usr/bin/env python3
"""Thin wrapper over pytest for the pantheon-sitehealth-emails harness.

Two audiences, one entry point (SPEC §5.8):
  ./run-tests                 human-readable, all tiers (incl. live)
  ./run-tests --fast          offline subset only  (-m "not live and not slow")
  ./run-tests --llm           terse, machine-parseable summary (for Claude Code)
  ./run-tests --coverage      pytest-cov (reported, no gate; in-process tiers)
  ./run-tests --update-goldens  refresh syrupy snapshots
  ./run-tests --record        re-record the terminus fixtures from the live test site

Any other arguments (-k EXPR, -m MARK, paths, ...) are passed straight through to pytest.
"""
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent


def ruff_argv():
    """How to invoke ruff here, or None if it cannot be invoked at all.

    `ruff` is not necessarily on PATH (this repo installs deps with uv), so fall back to
    `uvx ruff`.  Mirrors .claude/hooks/ruff-check.sh -- the two must agree on the binary
    just as they agree on the rule set (both read pyproject.toml; neither passes --select).
    """
    if shutil.which("ruff"):
        return ["ruff"]
    if shutil.which("uvx"):
        return ["uvx", "ruff"]
    return None


def pyright_argv():
    """How to invoke pyright here, or None.  Same fallback pattern as ruff_argv()."""
    if shutil.which("pyright"):
        return ["pyright"]
    if shutil.which("uvx"):
        return ["uvx", "pyright"]
    return None


def run_gates():
    """The lint + type gates.  Returns an exit code; 0 means every gate is clean.

    Three gates run in order, each aborting the step on the first nonzero result -- exactly
    like the single lint call this generalized -- so a later gate's green never hides an
    earlier gate's red:
      1. ruff, the NARROW PD rule set from pyproject.toml (E722/BLE001/S105/S106) -- each
         mechanizes a directive in prompts/directives.md; runs EVERYWHERE, including the
         files ruff-broad.toml grandfathers.
      2. ruff, the BROAD campaign ratchet from ruff-broad.toml (select=ALL minus a
         grandfathered exclude list; CAMPAIGN.md section 13).
      3. pyright, standard mode over psh/ minus _legacy.py (pyproject [tool.pyright]).

    Each gate prints a one-line label first, so a failure names its own gate (PD#1:
    failures surfaced actionably to the operator).  No --select on either ruff pass: the
    config files are the single source of truth, matching .claude/hooks/ruff-check.sh.
    Output is `concise`, so a ruff finding names the file, line, and rule.
    """
    argv = ruff_argv()
    if argv is None:
        # PD#1, zero silent failures: a gate that cannot run must not quietly stop gating.
        # Skipping here would let E722/BLE001/S105 land while the suite still reported green
        # -- an instrument that lies (PD#14).  Fail loudly and actionably instead.
        print(
            "ERROR: neither `ruff` nor `uvx` is on PATH, so the lint gate cannot run.\n"
            "       The suite is NOT green without it -- it is unverified.\n"
            "       Install uv (see README.md) or `pip install ruff`.",
            file=sys.stderr,
        )
        return 1

    print("Linting (ruff, narrow PD set) ...")
    completed = subprocess.call(
        [*argv, "check", "--output-format", "concise", "."], cwd=str(ROOT)
    )
    if completed != 0:
        print(
            "\nLint gate FAILED -- fix the findings above, or add a noqa WITH AN INLINE\n"
            "REASON if the code is deliberate (a bare noqa is a silent failure).\n"
            "These rules mechanize prompts/directives.md PD#2 and PD#6; they are not style.",
            file=sys.stderr,
        )
        return completed

    print("Linting (ruff-broad.toml, campaign ratchet) ...")
    completed = subprocess.call(
        [*argv, "check", "--config", "ruff-broad.toml", "--output-format", "concise", "."],
        cwd=str(ROOT),
    )
    if completed != 0:
        print(
            "\nBroad lint gate FAILED (ruff-broad.toml, campaign ratchet) -- fix the findings\n"
            "above, or add a justified ignore/noqa.  An increment un-grandfathers a file by\n"
            "deleting it from ruff-broad.toml's exclude list, so a clean tree is the entry fee.",
            file=sys.stderr,
        )
        return completed

    print("Type-checking (pyright, campaign ratchet) ...")
    pargv = pyright_argv()
    if pargv is None:
        # PD#1 again: pyright missing must FAIL, never silently skip -- a gate that does not
        # run is the shim failure mode CLAUDE.md warns about (a green that was never earned).
        print(
            "ERROR: neither `pyright` nor `uvx` is on PATH, so the type gate cannot run.\n"
            "       The suite is NOT green without it -- it is unverified.\n"
            "       Install it via `uv pip install .[test]` (adds pyright) or `pip install pyright`.",
            file=sys.stderr,
        )
        return 1
    completed = subprocess.call([*pargv], cwd=str(ROOT))
    if completed != 0:
        print(
            "\nType gate FAILED (pyright, campaign ratchet) -- fix the type findings above.\n"
            "Scope is psh/ minus _legacy.py; it ratchets up as increments move typed code in.",
            file=sys.stderr,
        )
    return completed


def main(argv):
    wrapper_flags = {
        "--fast", "--llm", "--human", "--coverage", "--update-goldens", "--record",
    }
    ours = [a for a in argv if a in wrapper_flags]
    passthrough = [a for a in argv if a not in wrapper_flags]

    if "--record" in ours:
        return subprocess.call([sys.executable, str(ROOT / "tests" / "tools" / "record.py")])

    # Lint AND type-check BEFORE pytest, and gate on them -- in --fast and full alike.  They
    # run in a few seconds, and a red gate here means the tree violates a directive or the
    # campaign ratchet, which no amount of green tests makes acceptable.  --record is exempt:
    # it re-records fixtures from live Pantheon and never reaches this line.
    rc = run_gates()
    if rc != 0:
        return rc

    pytest_args = ["-p", "no:cacheprovider"]

    if "--fast" in ours:
        pytest_args += ["-m", "not live and not slow"]
    if "--llm" in ours:
        # Terse and machine-parseable: quiet, short tracebacks, no color/header, plus the
        # conftest --llm summary hook (LLM_SUMMARY / FAILED <nodeid> lines).
        pytest_args += ["--llm", "-q", "--tb=short", "--color=no", "--no-header"]
    if "--coverage" in ours:
        pytest_args += ["--cov", "--cov-report=term-missing"]
    if "--update-goldens" in ours:
        pytest_args += ["--snapshot-update"]

    pytest_args += passthrough
    return subprocess.call([sys.executable, "-m", "pytest", *pytest_args], cwd=str(ROOT))


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
