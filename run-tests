#!/usr/bin/env python3
"""Thin wrapper over pytest for the pantheon-sitehealth-emails harness.

Two audiences, one entry point (SPEC §5.8):
  ./run-tests                 human-readable, all tiers (incl. live)
  ./run-tests --fast          offline subset only  (-m "not live and not slow")
  ./run-tests --llm           terse, machine-parseable summary (for Claude Code)
  ./run-tests --coverage      pytest-cov (reported, no gate; in-process tiers)
  ./run-tests --update-goldens  refresh syrupy snapshots
  ./run-tests --record        re-record the terminus fixtures from the live test site

Any other arguments (-k EXPR, -m MARK, paths, ...) are passed straight through to pytest.
"""
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent


def ruff_argv():
    """How to invoke ruff here, or None if it cannot be invoked at all.

    `ruff` is not necessarily on PATH (this repo installs deps with uv), so fall back to
    `uvx ruff`.  Mirrors .claude/hooks/ruff-check.sh -- the two must agree on the binary
    just as they agree on the rule set (both read pyproject.toml; neither passes --select).
    """
    if shutil.which("ruff"):
        return ["ruff"]
    if shutil.which("uvx"):
        return ["uvx", "ruff"]
    return None


def run_ruff():
    """The lint gate.  Returns an exit code; 0 means clean.

    Runs the NARROW rule set from pyproject.toml (E722/BLE001/S105/S106) -- each of which
    mechanizes a directive in prompts/directives.md.  No --select here: pyproject is the
    single source of truth, and duplicating the flags would be a second one.

    Output is `concise`, so a finding names the file, line, and rule.  "lint failed" is not
    an acceptable diagnostic (PD#5: failures surfaced actionably to the operator).
    """
    argv = ruff_argv()
    if argv is None:
        # PD#1, zero silent failures: a gate that cannot run must not quietly stop gating.
        # Skipping here would let E722/BLE001/S105 land while the suite still reported green
        # -- an instrument that lies (PD#14).  Fail loudly and actionably instead.
        print(
            "ERROR: neither `ruff` nor `uvx` is on PATH, so the lint gate cannot run.\n"
            "       The suite is NOT green without it -- it is unverified.\n"
            "       Install uv (see README.md) or `pip install ruff`.",
            file=sys.stderr,
        )
        return 1

    print("Linting (ruff, narrow rule set from pyproject.toml) ...")
    completed = subprocess.call(
        [*argv, "check", "--output-format", "concise", "."], cwd=str(ROOT)
    )
    if completed != 0:
        print(
            "\nLint gate FAILED -- fix the findings above, or add a noqa WITH AN INLINE\n"
            "REASON if the code is deliberate (a bare noqa is a silent failure).\n"
            "These rules mechanize prompts/directives.md PD#2 and PD#6; they are not style.",
            file=sys.stderr,
        )
    return completed


def main(argv):
    wrapper_flags = {
        "--fast", "--llm", "--human", "--coverage", "--update-goldens", "--record",
    }
    ours = [a for a in argv if a in wrapper_flags]
    passthrough = [a for a in argv if a not in wrapper_flags]

    if "--record" in ours:
        return subprocess.call([sys.executable, str(ROOT / "tests" / "tools" / "record.py")])

    # Lint BEFORE pytest, and gate on it -- in --fast and full alike.  It runs in about a
    # second, and a red gate here means the tree violates a directive, which no amount of
    # green tests makes acceptable.  --record is exempt: it re-records fixtures from live
    # Pantheon and never reaches this line.
    rc = run_ruff()
    if rc != 0:
        return rc

    pytest_args = ["-p", "no:cacheprovider"]

    if "--fast" in ours:
        pytest_args += ["-m", "not live and not slow"]
    if "--llm" in ours:
        # Terse and machine-parseable: quiet, short tracebacks, no color/header, plus the
        # conftest --llm summary hook (LLM_SUMMARY / FAILED <nodeid> lines).
        pytest_args += ["--llm", "-q", "--tb=short", "--color=no", "--no-header"]
    if "--coverage" in ours:
        pytest_args += ["--cov", "--cov-report=term-missing"]
    if "--update-goldens" in ours:
        pytest_args += ["--snapshot-update"]

    pytest_args += passthrough
    return subprocess.call([sys.executable, "-m", "pytest", *pytest_args], cwd=str(ROOT))


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
