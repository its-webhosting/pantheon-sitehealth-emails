{
  "mcpServers": {
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--executablePath",
        "/usr/local/share/ms-playwright/chrome-current/chrome-linux/chrome",
        "--chromeArg=--no-sandbox"
      ]
    }
  }
}
